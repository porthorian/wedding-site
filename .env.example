# reCAPTCHA (v3)
# Used by the RSVP lookup and submit endpoints.
RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET=your_recaptcha_secret_here

# Optional hardening
RECAPTCHA_EXPECTED_ACTION=rsvp_submit
RECAPTCHA_MINIMUM_SCORE=0.5

# Local development convenience (DO NOT enable in production)
RECAPTCHA_BYPASS=false

# Google Sheets (guest lookup + RSVP storage)
# Share the sheet with the service account email below.
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheet_id_here
GOOGLE_SHEETS_WORKSHEET_NAME=RSVPs
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# Discord RSVP notifications
# Create an incoming webhook for the Discord channel that should receive RSVP notices and RSVP error reports.
DISCORD_RSVP_WEBHOOK_URL=

# Public site URL for canonical + social OG absolute links
# Example: https://wedding.example.com
NUXT_PUBLIC_SITE_URL=
